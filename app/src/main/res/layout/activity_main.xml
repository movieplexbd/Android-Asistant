<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nexus_surface"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nexus_primary">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/nexus_primary"
            app:title="@string/title_main"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STT BANNER (shown only when STT engine is missing) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sttWarningCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/state_thinking"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VOICE NOT AVAILABLE"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="This phone has no Speech-to-Text engine. Type your command in the chat box below — Jarvis still works."
                        android:textColor="@color/black"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/installSttButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:text="Install Google Speech Services"
                        android:textColor="@color/black"
                        android:textAllCaps="false"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- LIVE STATUS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/nexus_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/stateDot"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@color/state_idle"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/statusTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="IDLE"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <com.assistant.android.ui.WaveformView
                        android:id="@+id/waveform"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="HEARING (live)"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/partialTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="HEARD"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/heardTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="UNDERSTOOD"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/understoodTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="ACTION"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/actionTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="REPLY"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/replyTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textIsSelectable="true" />

                    <TextView
                        android:id="@+id/statsTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Commands: 0 • Routines: 0 • Translations: 0 • Errors: 0"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ NEW: TEXT CHAT INTERFACE ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/nexus_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/nexus_secondary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="CHAT WITH JARVIS"
                            android:textColor="@color/nexus_secondary"
                            android:textSize="12sp"
                            android:letterSpacing="0.2"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clearChatButton"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Clear"
                            android:textAllCaps="false"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Type commands like: ammu ke call koro, open whatsapp, set alarm 7am"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp" />

                    <ScrollView
                        android:id="@+id/chatScroll"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="10dp"
                        android:background="@color/nexus_surface"
                        android:padding="10dp"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/chatHistoryTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp"
                            android:text="No messages yet. Type a command below to begin."
                            android:textColor="@color/white"
                            android:textIsSelectable="true"
                            android:textSize="13sp" />
                    </ScrollView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/chatInputEdit"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:background="@color/nexus_surface"
                            android:hint="Type a command…"
                            android:imeOptions="actionSend"
                            android:inputType="text|textCapSentences|textAutoCorrect"
                            android:padding="12dp"
                            android:textColor="@color/white"
                            android:textColorHint="#808AB0"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/sendChatButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:text="Send"
                            android:textAllCaps="false"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ NEW: QUICK ACTIONS ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/nexus_card"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="QUICK ACTIONS"
                        android:textColor="@color/nexus_secondary"
                        android:textSize="12sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/quickActionsGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="6dp"
                        app:chipSpacingVertical="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CONTROL BUTTONS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/voiceButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="Start Assistant"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wakeWordButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="Start Wake Word (Hey Jarvis)"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_silent_mode_off"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/overlayButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="Toggle Floating Bubble"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:strokeColor="@color/nexus_secondary"
                app:icon="@android:drawable/ic_menu_view"
                app:iconGravity="textStart"
                app:iconTint="@color/nexus_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testVoiceButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="Test Voice / Mic Diagnostics"
                android:textAllCaps="false"
                android:textColor="@color/nexus_secondary"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconGravity="textStart"
                app:iconTint="@color/nexus_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settingsButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="API Settings (paste new key here)"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:strokeColor="@color/nexus_card_alt"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconGravity="textStart"
                app:iconTint="@color/state_thinking" />

            <!-- DEBUG CONSOLE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/nexus_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/state_error"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="DEBUG / BUG CONSOLE"
                            android:textColor="@color/state_error"
                            android:textSize="12sp"
                            android:letterSpacing="0.2"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/copyDebugButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Copy"
                            android:textAllCaps="false"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clearDebugButton"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Clear"
                            android:textAllCaps="false"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Last failure (short)"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/errorShortTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="No errors yet."
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Error detail (full)"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/errorDetailTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/exportBugButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="Export Full Bug Report (share / save)"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        app:cornerRadius="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="ACTIVITY LOG"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/logTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="No activity yet."
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
