<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JarvisCEOTitan" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Theme.JarvisCEOTitan.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A84FF</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_btn_speak_now</item>
        <item name="postSplashScreenTheme">@style/Theme.JarvisCEOTitan</item>
    </style>
</resources>
